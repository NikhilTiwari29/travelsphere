# Shared MySQL root password used to provision all Compose databases and connect services.
MYSQL_ROOT_PASSWORD=replace-with-a-strong-local-development-password

# Shared JWT signing secret passed to user-service and api-gateway.
JWT_SECRET=replace-with-a-cryptographically-random-secret-at-least-32-bytes

# Initial administrator credentials passed to user-service.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-unique-password
ADMIN_FULL_NAME=System Administrator

# Payment gateway credentials passed to payment-service.
RAZORPAY_API_KEY=replace-with-your-razorpay-key-id
RAZORPAY_API_SECRET=replace-with-your-razorpay-key-secret
STRIPE_API_KEY=replace-with-your-stripe-secret-key
